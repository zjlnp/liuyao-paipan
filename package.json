{
  "name": "liuyao-paipan",
  "version": "1.0.0",
  "description": "六爻排盘 — 京房八宫纳甲装卦法，参照增删卜易",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac dmg",
    "build:dir": "electron-builder --mac dmg --dir"
  },
  "build": {
    "appId": "com.liuyao.paipan",
    "productName": "六爻排盘",
    "directories": {
      "output": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "style.css",
      "app.js",
      "data.js",
      "zhuanggua.js",
      "ganzhi.js",
      "data/hexagrams.json",
      "icons/*"
    ],
    "electronDownload": {
      "mirror": "https://cdn.npmmirror.com/binaries/electron/"
    },
    "mac": {
      "category": "public.app-category.reference",
      "target": "dmg",
      "icon": "icons/icon.icns"
    },
    "dmg": {
      "title": "六爻排盘",
      "window": {
        "width": 500,
        "height": 400
      }
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^25.0.0"
  }
}
